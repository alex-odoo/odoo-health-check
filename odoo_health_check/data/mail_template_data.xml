<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="mail_template_cron_failure" model="mail.template">
        <field name="name">Odoo Health Check: Cron Failure</field>
        <field name="model_id" ref="model_ir_cron_history"/>
        <field name="subject">[Odoo Health] Cron failure: {{ object.cron_id.name }} on {{ object.server_name }}</field>
        <field name="email_from">{{ (object.env.company.email or user.email_formatted) }}</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif;font-size:14px;color:#333">
                <p>A scheduled action has <strong style="color:#b00020">failed</strong> on server <strong t-out="object.server_name"/>.</p>
                <table style="border-collapse:collapse;margin:12px 0">
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Scheduled action</td><td><strong t-out="object.cron_id.name"/></td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Started</td><td t-out="object.date_start"/></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Ended</td><td t-out="object.date_end"/></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Duration</td><td><t t-out="object.duration_sec"/> s</td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Server</td><td t-out="object.server_name"/></tr>
                </table>
                <p style="color:#666">Error traceback:</p>
                <pre style="background:#f5f5f5;padding:12px;border-left:4px solid #b00020;overflow-x:auto" t-out="object.error_traceback"/>
                <p style="margin-top:18px;color:#888;font-size:12px">
                    Sent by <strong>Odoo Health Check</strong>. Manage recipients in Settings -&gt; Health Check.
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_disk_alert" model="mail.template">
        <field name="name">Odoo Health Check: Disk Alert</field>
        <field name="model_id" ref="model_health_check_result"/>
        <field name="subject">[Odoo Health] Disk {{ object.status }}: {{ object.mount_path }} at {{ '%.1f' % (object.used_pct or 0) }}% used</field>
        <field name="email_from">{{ (object.env.company.email or user.email_formatted) }}</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif;font-size:14px;color:#333">
                <p>Disk usage on <strong t-out="object.mount_path"/> has reached
                   <strong t-out="object.status"/>:
                   <strong t-out="'%.1f' % (object.used_pct or 0)"/>% used.</p>
                <table style="border-collapse:collapse;margin:12px 0">
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Check</td><td t-out="object.check_type"/></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Mount</td><td><strong t-out="object.mount_path"/></td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Status</td><td t-out="object.status"/></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Used</td><td><t t-out="'%.2f' % (object.used_pct or 0)"/>%</td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Total</td><td><t t-out="'%.2f' % ((object.total_bytes or 0) / (1024.0 ** 3))"/> GB</td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Free</td><td><t t-out="'%.2f' % ((object.free_bytes or 0) / (1024.0 ** 3))"/> GB</td></tr>
                    <tr><td style="padding:4px 12px 4px 0;color:#666">Time</td><td t-out="object.date"/></tr>
                </table>
                <p style="margin-top:18px;color:#888;font-size:12px">
                    One alert per worsening transition. Manage thresholds and recipients in Settings -&gt; Health Check.
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_pg_monthly" model="mail.template">
        <field name="name">Odoo Health Check: Monthly PG Report</field>
        <field name="model_id" ref="model_health_check_result"/>
        <field name="subject">[Odoo Health] PG monthly report: {{ object.env.cr.dbname }} ({{ object.date and object.date.strftime('%Y-%m') or '' }})</field>
        <field name="email_from">{{ (object.env.company.email or user.email_formatted) }}</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif;font-size:14px;color:#333">
                <t t-set="data" t-value="object._get_parsed_details()"/>
                <p>Monthly PostgreSQL growth report for database
                   <strong t-out="data.get('db_name', '?')"/>.</p>
                <p>
                    Total DB size: <strong t-out="object._human_bytes(data.get('total_db_bytes', 0))"/>
                    <t t-if="data.get('total_db_bytes_delta') is not None">
                        (<t t-out="object._human_delta_bytes(data.get('total_db_bytes_delta'))"/> vs previous report)
                    </t>
                </p>
                <h3 style="margin-top:18px">Top tables</h3>
                <table style="border-collapse:collapse;font-size:13px">
                    <thead>
                        <tr style="background:#f5f5f5">
                            <th style="text-align:left;padding:6px 12px;border-bottom:1px solid #ddd">Table</th>
                            <th style="text-align:right;padding:6px 12px;border-bottom:1px solid #ddd">Total size</th>
                            <th style="text-align:right;padding:6px 12px;border-bottom:1px solid #ddd">Δ Size</th>
                            <th style="text-align:right;padding:6px 12px;border-bottom:1px solid #ddd">Rows (est.)</th>
                            <th style="text-align:right;padding:6px 12px;border-bottom:1px solid #ddd">Δ Rows</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="data.get('tables', [])" t-as="t">
                            <td style="padding:4px 12px;border-bottom:1px solid #eee" t-out="t.get('name')"/>
                            <td style="padding:4px 12px;text-align:right;border-bottom:1px solid #eee" t-out="object._human_bytes(t.get('total_bytes', 0))"/>
                            <td style="padding:4px 12px;text-align:right;border-bottom:1px solid #eee">
                                <t t-if="t.get('total_bytes_delta') is None">new</t>
                                <t t-else="" t-out="object._human_delta_bytes(t.get('total_bytes_delta'))"/>
                            </td>
                            <td style="padding:4px 12px;text-align:right;border-bottom:1px solid #eee" t-out="t.get('row_estimate', 0)"/>
                            <td style="padding:4px 12px;text-align:right;border-bottom:1px solid #eee">
                                <t t-if="t.get('row_estimate_delta') is None">new</t>
                                <t t-elif="t.get('row_estimate_delta') &gt; 0">+<t t-out="t.get('row_estimate_delta')"/></t>
                                <t t-else="" t-out="t.get('row_estimate_delta')"/>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <p style="margin-top:18px;color:#888;font-size:12px">
                    Sent monthly by <strong>Odoo Health Check</strong>. Row counts are PostgreSQL estimates from `pg_class.reltuples` (last ANALYZE), not exact COUNT(*). Manage recipients in Settings -&gt; Health Check.
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
