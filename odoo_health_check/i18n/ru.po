#. module: odoo_health_check
#: model:mail.template,body_html:odoo_health_check.mail_template_pg_monthly
msgid ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#1f7a8c'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"th_style\" t-value=\"'text-align:left;padding:6px 12px;border-bottom:1px solid #ddd'\"/>\n"
"                <t t-set=\"th_right\" t-value=\"'text-align:right;padding:6px 12px;border-bottom:1px solid #ddd'\"/>\n"
"                <t t-set=\"td_style\" t-value=\"'padding:4px 12px;border-bottom:1px solid #eee'\"/>\n"
"                <t t-set=\"td_right\" t-value=\"'padding:4px 12px;text-align:right;border-bottom:1px solid #eee'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <t t-set=\"data\" t-value=\"object._get_parsed_details()\"/>\n"
"                <p>Monthly PostgreSQL growth report for database\n"
"                   <strong t-out=\"data.get('db_name', '?')\"/>.</p>\n"
"                <p>\n"
"                    Total DB size: <strong t-out=\"object._human_bytes(data.get('total_db_bytes', 0))\"/>\n"
"                    <t t-if=\"data.get('total_db_bytes_delta') is not None\">\n"
"                        (<t t-out=\"object._human_delta_bytes(data.get('total_db_bytes_delta'))\"/> vs previous report)\n"
"                    </t>\n"
"                </p>\n"
"                <h3 style=\"margin-top:18px\">Top tables</h3>\n"
"                <table style=\"border-collapse:collapse;font-size:13px\">\n"
"                    <thead>\n"
"                        <tr style=\"background:#f5f5f5\">\n"
"                            <th t-attf-style=\"{{ th_style }}\">Table</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Total size</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Î Size</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Rows (est.)</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Î Rows</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"data.get('tables', [])\" t-as=\"t\">\n"
"                            <td t-attf-style=\"{{ td_style }}\" t-out=\"t.get('name')\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\" t-out=\"object._human_bytes(t.get('total_bytes', 0))\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\">\n"
"                                <t t-if=\"t.get('total_bytes_delta') is None\">new</t>\n"
"                                <t t-else=\"\" t-out=\"object._human_delta_bytes(t.get('total_bytes_delta'))\"/>\n"
"                            </td>\n"
"                            <td t-attf-style=\"{{ td_right }}\" t-out=\"t.get('row_estimate', 0)\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\">\n"
"                                <t t-if=\"t.get('row_estimate_delta') is None\">new</t>\n"
"                                <t t-elif=\"t.get('row_estimate_delta') &gt; 0\">+<t t-out=\"t.get('row_estimate_delta')\"/></t>\n"
"                                <t t-else=\"\" t-out=\"t.get('row_estimate_delta')\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"                <p style=\"margin-top:18px\">\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        View in PG Reports\n"
"                    </a>\n"
"                </p>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    Sent monthly by <strong>Odoo Health Check</strong>. Row counts are PostgreSQL estimates from `pg_class.reltuples` (last ANALYZE), not exact COUNT(*). Manage recipients in Settings -&gt; Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#1f7a8c'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"th_style\" t-value=\"'text-align:left;padding:6px 12px;border-bottom:1px solid #ddd'\"/>\n"
"                <t t-set=\"th_right\" t-value=\"'text-align:right;padding:6px 12px;border-bottom:1px solid #ddd'\"/>\n"
"                <t t-set=\"td_style\" t-value=\"'padding:4px 12px;border-bottom:1px solid #eee'\"/>\n"
"                <t t-set=\"td_right\" t-value=\"'padding:4px 12px;text-align:right;border-bottom:1px solid #eee'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <t t-set=\"data\" t-value=\"object._get_parsed_details()\"/>\n"
"                <p>Ежемесячный отчёт роста PostgreSQL для базы данных \n"
"                   <strong t-out=\"data.get('db_name', '?')\"/>.</p>\n"
"                <p>\n"
"                    Общий размер БД: <strong t-out=\"object._human_bytes(data.get('total_db_bytes', 0))\"/>\n"
"                    <t t-if=\"data.get('total_db_bytes_delta') is not None\">\n"
"                        (<t t-out=\"object._human_delta_bytes(data.get('total_db_bytes_delta'))\"/> по сравнению с прошлым отчётом)\n"
"                    </t>\n"
"                </p>\n"
"                <h3 style=\"margin-top:18px\">Крупнейшие таблицы</h3>\n"
"                <table style=\"border-collapse:collapse;font-size:13px\">\n"
"                    <thead>\n"
"                        <tr style=\"background:#f5f5f5\">\n"
"                            <th t-attf-style=\"{{ th_style }}\">Таблица</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Общий размер</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Δ Размер</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Строки (оценка)</th>\n"
"                            <th t-attf-style=\"{{ th_right }}\">Δ Строки</th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <tr t-foreach=\"data.get('tables', [])\" t-as=\"t\">\n"
"                            <td t-attf-style=\"{{ td_style }}\" t-out=\"t.get('name')\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\" t-out=\"object._human_bytes(t.get('total_bytes', 0))\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\">\n"
"                                <t t-if=\"t.get('total_bytes_delta') is None\">новая</t>\n"
"                                <t t-else=\"\" t-out=\"object._human_delta_bytes(t.get('total_bytes_delta'))\"/>\n"
"                            </td>\n"
"                            <td t-attf-style=\"{{ td_right }}\" t-out=\"t.get('row_estimate', 0)\"/>\n"
"                            <td t-attf-style=\"{{ td_right }}\">\n"
"                                <t t-if=\"t.get('row_estimate_delta') is None\">новая</t>\n"
"                                <t t-elif=\"t.get('row_estimate_delta') &gt; 0\">+<t t-out=\"t.get('row_estimate_delta')\"/></t>\n"
"                                <t t-else=\"\" t-out=\"t.get('row_estimate_delta')\"/>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </tbody>\n"
"                </table>\n"
"                <p style=\"margin-top:18px\">\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        Открыть в отчётах PG\n"
"                    </a>\n"
"                </p>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    Ежемесячно отправляется модулем <strong>Odoo Health Check</strong>. Количество строк - оценка PostgreSQL из `pg_class.reltuples` (последний ANALYZE), не точный COUNT(*). Управление получателями: Настройки -> Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "

#. module: odoo_health_check
#: model:mail.template,body_html:odoo_health_check.mail_template_disk_alert
msgid ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#b00020' if object.status == 'critical' else '#b08000'\"/>\n"
"                <t t-set=\"badge_text\" t-value=\"object.status.upper() if object.status else 'WARNING'\"/>\n"
"                <t t-set=\"badge_style\" t-value=\"'display:inline-block;padding:4px 12px;background:' + accent + ';color:#fff;font-weight:bold;border-radius:3px;font-size:12px;letter-spacing:0.5px'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"kv_label\" t-value=\"'padding:4px 12px 4px 0;color:#666'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <div t-attf-style=\"{{ badge_style }}\" t-out=\"badge_text\"/>\n"
"                <p style=\"margin-top:12px\">Disk usage on <strong t-out=\"object.mount_path\"/> has reached\n"
"                   <strong t-out=\"object.status\"/>:\n"
"                   <strong t-out=\"'%.1f' % (object.used_pct or 0)\"/>% used.</p>\n"
"                <table style=\"border-collapse:collapse;margin:12px 0\">\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Check</td><td t-out=\"object.check_type\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Mount</td><td><strong t-out=\"object.mount_path\"/></td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Status</td><td t-out=\"object.status\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Used</td><td><t t-out=\"'%.2f' % (object.used_pct or 0)\"/>%</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Total</td><td><t t-out=\"'%.2f' % ((object.total_bytes or 0) / (1024.0 ** 3))\"/> GB</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Free</td><td><t t-out=\"'%.2f' % ((object.free_bytes or 0) / (1024.0 ** 3))\"/> GB</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Time</td><td t-out=\"object.date\"/></tr>\n"
"                </table>\n"
"                <p>\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        View in Disk Checks\n"
"                    </a>\n"
"                </p>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    One alert per worsening transition. Manage thresholds and recipients in Settings -&gt; Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#b00020' if object.status == 'critical' else '#b08000'\"/>\n"
"                <t t-set=\"badge_text\" t-value=\"object.status.upper() if object.status else 'WARNING'\"/>\n"
"                <t t-set=\"badge_style\" t-value=\"'display:inline-block;padding:4px 12px;background:' + accent + ';color:#fff;font-weight:bold;border-radius:3px;font-size:12px;letter-spacing:0.5px'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"kv_label\" t-value=\"'padding:4px 12px 4px 0;color:#666'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <div t-attf-style=\"{{ badge_style }}\" t-out=\"badge_text\"/>\n"
"                <p style=\"margin-top:12px\">Использование диска <strong t-out=\"object.mount_path\"/> достигло \n"
"                   <strong t-out=\"object.status\"/>:\n"
"                   <strong t-out=\"'%.1f' % (object.used_pct or 0)\"/>% использовано.</p>\n"
"                <table style=\"border-collapse:collapse;margin:12px 0\">\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Проверка</td><td t-out=\"object.check_type\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Монтирование</td><td><strong t-out=\"object.mount_path\"/></td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Статус</td><td t-out=\"object.status\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Использовано</td><td><t t-out=\"'%.2f' % (object.used_pct or 0)\"/>%</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Всего</td><td><t t-out=\"'%.2f' % ((object.total_bytes or 0) / (1024.0 ** 3))\"/> GB</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Свободно</td><td><t t-out=\"'%.2f' % ((object.free_bytes or 0) / (1024.0 ** 3))\"/> GB</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Время</td><td t-out=\"object.date\"/></tr>\n"
"                </table>\n"
"                <p>\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        Открыть в проверках диска\n"
"                    </a>\n"
"                </p>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    Одно письмо на каждое ухудшение. Управление порогами и получателями: Настройки -> Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "

#. module: odoo_health_check
#: model:mail.template,body_html:odoo_health_check.mail_template_cron_failure
msgid ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#b00020'\"/>\n"
"                <t t-set=\"badge_style\" t-value=\"'display:inline-block;padding:4px 12px;background:' + accent + ';color:#fff;font-weight:bold;border-radius:3px;font-size:12px;letter-spacing:0.5px'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"kv_label\" t-value=\"'padding:4px 12px 4px 0;color:#666'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <div t-attf-style=\"{{ badge_style }}\">CRITICAL</div>\n"
"                <p style=\"margin-top:12px\">A scheduled action has <strong t-attf-style=\"color:{{ accent }}\">failed</strong> on server <strong t-out=\"object.server_name\"/>.</p>\n"
"                <table style=\"border-collapse:collapse;margin:12px 0\">\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Scheduled action</td><td><strong t-out=\"object.cron_id.name\"/></td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Started</td><td t-out=\"object.date_start\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Ended</td><td t-out=\"object.date_end\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Duration</td><td><t t-out=\"object.duration_sec\"/> s</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Server</td><td t-out=\"object.server_name\"/></tr>\n"
"                </table>\n"
"                <p>\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        View in Cron History\n"
"                    </a>\n"
"                </p>\n"
"                <details style=\"margin-top:18px\">\n"
"                    <summary style=\"cursor:pointer;color:#666;font-size:13px;padding:6px 0\">\n"
"                        Show full error traceback\n"
"                    </summary>\n"
"                    <pre t-attf-style=\"background:#f5f5f5;padding:12px;border-left:4px solid {{ accent }};overflow-x:auto;margin-top:8px;font-size:12px\" t-out=\"object.error_traceback\"/>\n"
"                </details>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    Sent by <strong>Odoo Health Check</strong>. Manage recipients in Settings -&gt; Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"font-family:Arial,sans-serif;font-size:14px;color:#333;max-width:720px\">\n"
"                <t t-set=\"accent\" t-value=\"'#b00020'\"/>\n"
"                <t t-set=\"badge_style\" t-value=\"'display:inline-block;padding:4px 12px;background:' + accent + ';color:#fff;font-weight:bold;border-radius:3px;font-size:12px;letter-spacing:0.5px'\"/>\n"
"                <t t-set=\"button_style\" t-value=\"'display:inline-block;padding:8px 16px;background:' + accent + ';color:#fff;text-decoration:none;border-radius:3px;font-weight:bold'\"/>\n"
"                <t t-set=\"kv_label\" t-value=\"'padding:4px 12px 4px 0;color:#666'\"/>\n"
"                <t t-set=\"footer_style\" t-value=\"'margin-top:24px;color:#888;font-size:12px'\"/>\n"
"                <div t-attf-style=\"{{ badge_style }}\">КРИТИЧНО</div>\n"
"                <p style=\"margin-top:12px\">Запланированное действие <strong t-attf-style=\"color:{{ accent }}\">завершилось с ошибкой</strong> на сервере <strong t-out=\"object.server_name\"/>.</p>\n"
"                <table style=\"border-collapse:collapse;margin:12px 0\">\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Запланированное действие</td><td><strong t-out=\"object.cron_id.name\"/></td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Начало</td><td t-out=\"object.date_start\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Окончание</td><td t-out=\"object.date_end\"/></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Длительность</td><td><t t-out=\"object.duration_sec\"/> с</td></tr>\n"
"                    <tr><td t-attf-style=\"{{ kv_label }}\">Сервер</td><td t-out=\"object.server_name\"/></tr>\n"
"                </table>\n"
"                <p>\n"
"                    <a t-att-href=\"object._action_url()\" t-attf-style=\"{{ button_style }}\">\n"
"                        Открыть в истории планировщика\n"
"                    </a>\n"
"                </p>\n"
"                <details style=\"margin-top:18px\">\n"
"                    <summary style=\"cursor:pointer;color:#666;font-size:13px;padding:6px 0\">\n"
"                        Показать полный traceback\n"
"                    </summary>\n"
"                    <pre t-attf-style=\"background:#f5f5f5;padding:12px;border-left:4px solid {{ accent }};overflow-x:auto;margin-top:8px;font-size:12px\" t-out=\"object.error_traceback\"/>\n"
"                </details>\n"
"                <p t-attf-style=\"{{ footer_style }}\">\n"
"                    Отправлено модулем <strong>Odoo Health Check</strong>. Управление получателями: Настройки -> Health Check.\n"
"                </p>\n"
"            </div>\n"
"        "

#. module: odoo_health_check
#: model:ir.model.fields,field_description:odoo_health_check.field_health_check_result__check_type
#: model_terms:ir.ui.view,arch_db:odoo_health_check.health_check_result_view_search
msgid "Check Type"
msgstr "Тип проверки"

#. module: odoo_health_check
#: model:ir.model.fields,help:odoo_health_check.field_res_config_settings__odoo_health_notify_emails
msgid "Comma-separated list of recipients that receive an email every time a scheduled action fails. Leave empty to disable."
msgstr "Список адресатов через запятую, получающих письмо при каждом сбое запланированного действия. Оставьте пустым, чтобы отключить."

#. module: odoo_health_check
#: model_terms:ir.ui.view,arch_db:odoo_health_check.res_config_settings_view_form
msgid "Comma-separated list of recipients. Leave empty to disable email alerts."
msgstr "Адресаты через запятую. Оставьте пустым, чтобы отключить email-оповещения."

#. module: odoo_health_check
#: model_terms:ir.ui.view,arch_db:odoo_health_check.res_config_settings_view_form
msgid "Comma-separated recipients for the monthly PostgreSQL growth report (sent on the 1st of each month at 08:00). Leave empty to disable email - the report row is still created."
msgstr "Адресаты через запятую для ежемесячного отчёта роста PostgreSQL (отправляется 1-го числа каждого месяца в 08:00). Оставьте пустым, чтобы отключить письмо: запись отчёта всё равно будет создана."

#. module: odoo_health_check
#: model:ir.model.fields,help:odoo_health_check.field_res_config_settings__odoo_health_disk_alert_emails
msgid "Comma-separated recipients that receive an email when disk usage transitions from ok to warn or critical (or from warn to critical). One email per worsening transition - no per-hour spam. Leave empty to disable."
